# API
# Optional JSON routing by chat model.
# Format:
# OPENAI_CHAT_MODEL_ROUTES={"openai/gpt-oss-120b":{"base_url":"https://.../v1","api_key":"..."}, "google/gemma-4-31B":{"base_url":"https://.../v1","api_key":"..."}}
OPENAI_CHAT_MODEL_ROUTES=
# Optional JSON routing by embedding model.
# OPENAI_EMBEDDING_MODEL_ROUTES={"nomic-ai/nomic-embed-text-v2-moe":{"base_url":"https://.../v1","api_key":"..."}, "BAAI/bge-m3":{"base_url":"https://.../v1","api_key":"..."}}
OPENAI_EMBEDDING_MODEL_ROUTES=
OPENAI_RERANKING_MODEL_ROUTES=
OPENAI_TRANSCRIPTION_MODEL_ROUTES=
REQUEST_GROUP=api-service
RETRY_ATTEMPTS=5
RETRY_BASE_SEC=0.5
RETRY_CAP_SEC=8
CONSUMER_NAME=

# Endpoint
ENDPOINT_API_KEY=
API_ENDPOINT_HOST=
API_ENDPOINT_PORT=
SYNC_TIMEOUT_MS=50000

# Redis
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=
REQUEST_STREAM=openai:requests
RESPONSE_STREAM_PREFIX=openai:responses
RESPONSE_TTL_SEC=300
